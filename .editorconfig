# EditorConfig — 统一基础编辑器行为
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown 行内换行可能有意义，保留行尾空格策略由作者控制
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
